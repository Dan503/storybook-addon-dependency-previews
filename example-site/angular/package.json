{
  "name": "taskbox",
  "version": "0.2.0",
  "description": "Starter template to get up and running quickly with Angular and Storybook",
  "author": "Chromatic <https://chromatic.com/>",
  "repository": {
    "type": "git",
    "url": "https://github.com/chromaui/intro-storybook-angular-template"
  },
  "bugs": {
    "url": "https://github.com/chromaui/intro-storybook-angular-template/issues"
  },
  "license": "MIT",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build": "pnpm run prep-sb-addon && ng build",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "storybook": "ng run taskbox:storybook",
    "build-storybook": "ng run taskbox:build-storybook",
    "init-msw": "msw init public/",
    "sb": "sb-deps --watch --run-storybook \"ng run taskbox:storybook\"",
    "sb:build": "pnpm run prep-sb-addon && node ../../storybook-addon-package/dist/cli/sb-deps.cjs && storybook build",
    "sb:deps": "sb-deps",
    "prep-sb-addon": "pnpm --filter storybook-addon-dependency-previews build"
  },
  "private": true,
  "dependencies": {
    "@angular/common": "^21.0.0",
    "@angular/compiler": "^21.0.0",
    "@angular/core": "^21.0.0",
    "@angular/forms": "^21.0.0",
    "@angular/platform-browser": "^21.0.0",
    "@angular/router": "^21.0.0",
    "@tailwindcss/postcss": "^4.2.1",
    "@tanstack/angular-form": "^1.28.6",
    "postcss": "^8.5.8",
    "rxjs": "~7.8.0",
    "tailwindcss": "^4.2.1",
    "tslib": "^2.3.0",
    "zone.js": "~0.15.0"
  },
  "devDependencies": {
    "@angular-devkit/architect": "^0.2100.0",
    "@angular-devkit/build-angular": "^21.0.0",
    "@angular-devkit/core": "^21.0.0",
    "@angular/build": "^21.0.4",
    "@angular/cli": "^21.0.4",
    "@angular/compiler-cli": "^21.0.0",
    "@angular/platform-browser-dynamic": "^21.0.0",
    "@compodoc/compodoc": "^1.1.32",
    "@storybook/addon-docs": "^10.2.14",
    "@storybook/angular": "^10.2.14",
    "dependency-cruiser": "^17.3.9",
    "example-site-shared": "workspace:*",
    "jsdom": "^27.1.0",
    "msw": "^2.12.7",
    "msw-storybook-addon": "^2.0.6",
    "storybook": "^10.2.14",
    "storybook-addon-dependency-previews": "workspace:*",
    "typescript": "~5.9.2",
    "vitest": "^4.0.8"
  },
  "prettier": {
    "printWidth": 100,
    "singleQuote": true,
    "overrides": [
      {
        "files": "*.html",
        "options": {
          "parser": "angular"
        }
      }
    ]
  }
}
