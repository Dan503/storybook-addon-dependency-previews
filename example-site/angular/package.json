{
	"name": "example-site-angular",
	"private": true,
	"license": "Apache-2.0",
	"type": "module",
	"scripts": {
		"dev": "ng serve --port 3000",
		"build": "ng build",
		"sb": "sb-deps --watch --run-storybook --storybook-cmd \"ng run angular:storybook\"",
		"sb:build": "pnpm --filter storybook-addon-dependency-previews build && node ../../storybook-addon-package/dist/cli/sb-deps.cjs && ng run angular:build-storybook",
		"sb:deps": "sb-deps",
		"lint": "eslint",
		"check": "prettier --write . && eslint --fix"
	},
	"dependencies": {
		"@angular/animations": "^21.0.0",
		"@angular/common": "^21.0.0",
		"@angular/compiler": "^21.0.0",
		"@angular/core": "^21.0.0",
		"@angular/forms": "^21.0.0",
		"@angular/platform-browser": "^21.0.0",
		"@angular/router": "^21.0.0",
		"example-site-shared": "workspace:*",
		"rxjs": "~7.8.0",
		"tslib": "^2.3.0",
		"zone.js": "~0.15.0"
	},
	"devDependencies": {
		"@angular/build": "^21.0.0",
		"@angular/cli": "^21.0.0",
		"@angular/compiler-cli": "^21.0.0",
		"@storybook/addon-docs": "^10.2.13",
		"@storybook/angular": "^10.2.13",
		"@tailwindcss/postcss": "^4.2.1",
		"@types/node": "^25.3.3",
		"@types/webpack-env": "^1.18.0",
		"dependency-cruiser": "^17.3.8",
		"postcss": "^8.5.8",
		"storybook": "^10.2.13",
		"storybook-addon-dependency-previews": "workspace:*",
		"tailwindcss": "^4.1.18",
		"typescript": "~5.9.0"
	}
}
